---
import { Code } from 'astro/components';
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/Sidebar.astro';
import { languages } from '../../i18n/ui';
import lessons from '../../data/lessons.json';
import { Terminal, Play } from '@lucide/astro';

export async function getStaticPaths() {
  const paths = [];
  for (const lang of Object.keys(languages)) {
    for (const lesson of lessons) {
      paths.push({
        params: { lang, path: lesson.path },
        props: { lesson },
      });
    }
  }
  return paths;
}

const { lang } = Astro.params;
const { lesson } = Astro.props;
const activeLang = lang as keyof typeof languages;


---

<Layout title={lesson.name}>
  <div class="app-container" id="app-container">
    <Sidebar activePath={lesson.path} activeLang={activeLang} />
    
    <!-- Code Editor Pane (Middle) -->
    <div class="code-pane">
      <div class="pane-header">
        <div class="filename-badge">
          <span class="file-icon"><Terminal size={16} /></span>
          <span class="filename-text">{lesson.filename}</span>
        </div>
        <div class="action-buttons">
          <a 
            href={`https://replit.com/github/huangsam/ultimate-python`} 
            target="_blank" 
            rel="noopener noreferrer" 
            class="action-btn btn-replit"
          >
            <span class="btn-icon"><Play size={14} fill="currentColor" /></span>
            <span class="btn-text-full">Run on Replit</span>
            <span class="btn-text-short">Run</span>
          </a>
        </div>
      </div>
      
      <div class="code-scroller">
        <Code code={lesson.code} lang="py" theme="github-dark" />
      </div>
    </div>
  </div>
</Layout>

<style>
  /* Three-pane layout split */
  .code-pane {
    flex: 1;
    display: flex;
    flex-direction: column;
    background-color: #1e1e1e; /* Dark editor background to contrast with sand UI */
    border-right: 1px solid var(--border-color);
    position: relative;
    overflow: hidden;
    container-type: inline-size;
    container-name: code-pane;
  }
  
  .pane-header {
    height: 60px;
    background-color: #252526;
    border-bottom: 1px solid #333333;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1.25rem;
    flex-shrink: 0;
  }

  :global(html.sidebar-transitioning) .pane-header {
    transition: padding-left var(--transition-speed);
  }

  :global(html.sidebar-collapsed) .pane-header {
    padding-left: 3.5rem;
  }
  
  .filename-badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-width: 0;
  }
  
  .file-icon {
    color: #858585;
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }
  
  .filename-text {
    font-family: var(--font-mono);
    color: #cccccc;
    font-size: 0.9rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  
  .action-buttons {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
  }
  
  .action-btn {
    padding: 0.5rem 0.9rem;
    border-radius: 4px;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    border: none;
    transition: all var(--transition-speed);
    display: inline-flex;
    align-items: center;
  }
  
  .btn-replit {
    background-color: #3c3c3c;
    color: #ffffff;
    text-decoration: none;
  }
  
  .btn-replit:hover {
    background-color: #4e4e4e;
  }

  .btn-text-short {
    display: none;
  }
  
  .btn-icon {
    margin-right: 0.4rem;
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  @container code-pane (max-width: 480px) {
    .btn-text-full {
      display: none;
    }
    .btn-text-short {
      display: inline;
    }
  }

  @container code-pane (max-width: 320px) {
    .btn-text-full {
      display: none;
    }
    .btn-text-short {
      display: none;
    }
    .btn-icon {
      margin-right: 0;
    }
    .action-btn {
      padding: 0.5rem 0.6rem;
    }
  }
  
  .code-scroller {
    flex: 1;
    overflow: auto;
    background-color: #1e1e1e;
    scrollbar-width: thin;
    scrollbar-color: #3e3e3e #1e1e1e;
  }
  
  .code-scroller::-webkit-scrollbar {
    width: 10px;
    height: 10px;
  }
  
  .code-scroller::-webkit-scrollbar-track {
    background: #1e1e1e;
  }
  
  .code-scroller::-webkit-scrollbar-thumb {
    background: #3e3e3e;
    border: 2px solid #1e1e1e;
    border-radius: 6px;
  }
  
  .code-scroller::-webkit-scrollbar-thumb:hover {
    background: #4f4f4f;
  }
  
  /* Override default Astro code element backgrounds */
  .code-scroller :global(pre) {
    background-color: transparent !important;
    padding: 1.5rem !important;
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    line-height: 1.5;
  }
  @media (max-width: 900px) {
    /* Stack container vertically */
    #app-container {
      flex-direction: column !important;
    }

    .code-pane {
      width: 100% !important;
      flex: 1;
      border-right: none;
    }
  }
</style>
