---
import { Code } from 'astro/components';
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/Sidebar.astro';
import { languages } from '../../i18n/ui';
import lessons from '../../data/lessons.json';
import { Terminal, Play, Copy, Check } from '@lucide/astro';

export async function getStaticPaths() {
  const paths = [];
  for (const lang of Object.keys(languages)) {
    for (const lesson of lessons) {
      paths.push({
        params: { lang, path: lesson.path },
        props: { lesson },
      });
    }
  }
  return paths;
}

const { lang } = Astro.params;
const { lesson } = Astro.props;
const activeLang = lang as keyof typeof languages;
---

<Layout title={lesson.name}>
  <div class="app-container" id="app-container">
    <Sidebar activePath={lesson.path} activeLang={activeLang} />

    <!-- Code Editor Pane (Middle) -->
    <div class="code-pane">
      <div class="pane-header">
        <div class="filename-badge">
          <span class="file-icon"><Terminal size={16} /></span>
          <span class="filename-text">{lesson.filename}</span>
          {
            lesson.annotation && (
              <span class="annotation-badge" title={lesson.annotation.feature}>
                {lesson.annotation.version}
              </span>
            )
          }
        </div>
        <div class="action-buttons">
          <button
            id="copy-code-btn"
            class="action-btn btn-copy"
            data-code={lesson.code}
            aria-label="Copy Code"
          >
            <span class="btn-icon btn-copy-icon"><Copy size={14} /></span>
            <span class="btn-icon btn-check-icon" style="display: none;"
              ><Check size={14} /></span
            >
            <span class="btn-text">Copy Code</span>
          </button>
          <a
            href={`https://replit.com/github/huangsam/ultimate-python`}
            target="_blank"
            rel="noopener noreferrer"
            class="action-btn btn-replit"
          >
            <span class="btn-icon"><Play size={14} fill="currentColor" /></span>
            <span class="btn-text-full">Run on Replit</span>
            <span class="btn-text-short">Run</span>
          </a>
        </div>
      </div>

      <div class="code-scroller">
        <Code code={lesson.code} lang="py" theme="github-dark" />
      </div>
    </div>
  </div>
</Layout>

<style>
  /* Three-pane layout split */
  .code-pane {
    flex: 1;
    display: flex;
    flex-direction: column;
    background-color: #1e1e1e; /* Dark editor background to contrast with sand UI */
    border-right: 1px solid var(--border-color);
    position: relative;
    overflow: hidden;
    container-type: inline-size;
    container-name: code-pane;
  }

  .pane-header {
    height: 60px;
    background-color: #252526;
    border-bottom: 1px solid #333333;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1.25rem;
    /* Constant padding-left to clear the floating sidebar toggle button in all */
    /* states (open/collapsed) without triggering layout reflow and text shifting. */
    padding-left: 3.5rem;
    flex-shrink: 0;
  }

  .filename-badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-width: 0;
  }

  .file-icon {
    color: #858585;
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .filename-text {
    font-family: var(--font-mono);
    color: #cccccc;
    font-size: 0.9rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .annotation-badge {
    background-color: rgba(45, 106, 79, 0.25);
    color: #52b788;
    font-size: 0.72rem;
    font-weight: 500;
    padding: 0.15rem 0.5rem;
    border-radius: 9999px;
    margin-left: 0.5rem;
    border: 1px solid rgba(82, 183, 136, 0.3);
    font-family: var(--font-sans);
    white-space: nowrap;
    cursor: help;
  }

  @media (width <= 480px) {
    .annotation-badge {
      display: none;
    }
  }

  .action-buttons {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .action-btn {
    padding: 0.5rem 0.9rem;
    border-radius: 4px;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    border: none;
    transition: all var(--transition-speed);
    display: inline-flex;
    align-items: center;
  }

  .btn-replit {
    background-color: #3c3c3c;
    color: #ffffff;
    text-decoration: none;
  }

  .btn-replit:hover {
    background-color: #4e4e4e;
  }

  .btn-text-short {
    display: none;
  }

  .btn-icon {
    margin-right: 0.4rem;
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  @media (width <= 969px) {
    .btn-text,
    .btn-text-full,
    .btn-text-short {
      display: none;
    }
    .btn-icon {
      margin-right: 0 !important;
    }
    .action-btn {
      padding: 0.5rem 0.6rem;
    }
  }

  .code-scroller {
    flex: 1;
    overflow: auto;
    background-color: #1e1e1e;
    scrollbar-width: thin;
    scrollbar-color: #3e3e3e #1e1e1e;
  }

  .code-scroller::-webkit-scrollbar {
    width: 10px;
    height: 10px;
  }

  .code-scroller::-webkit-scrollbar-track {
    background: #1e1e1e;
  }

  .code-scroller::-webkit-scrollbar-thumb {
    background: #3e3e3e;
    border: 2px solid #1e1e1e;
    border-radius: 6px;
  }

  .code-scroller::-webkit-scrollbar-thumb:hover {
    background: #4f4f4f;
  }

  /* Override default Astro code element backgrounds */
  .code-scroller :global(pre) {
    background-color: transparent !important;
    padding: 1.5rem !important;
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .btn-copy {
    background-color: #2d2d30;
    color: #cccccc;
    border: 1px solid #3e3e42;
  }

  .btn-copy:hover {
    background-color: #3e3e42;
    color: #ffffff;
  }

  .btn-copy.copied {
    background-color: var(--forest-green-light) !important;
    border-color: var(--forest-green-light) !important;
    color: #ffffff !important;
  }

  @media (width <= 900px) {
    /* Stack container vertically */
    #app-container {
      flex-direction: column !important;
    }

    .code-pane {
      width: 100% !important;
      flex: 1;
      border-right: none;
    }
  }
</style>

<script>
  if (!(window as any).copyListenerBound) {
    (window as any).copyListenerBound = true;

    document.addEventListener('click', async (e) => {
      const copyBtn = (e.target as HTMLElement).closest(
        '#copy-code-btn'
      ) as HTMLButtonElement;
      if (!copyBtn) return;

      const copyIcon = copyBtn.querySelector('.btn-copy-icon') as HTMLElement;
      const checkIcon = copyBtn.querySelector('.btn-check-icon') as HTMLElement;
      const btnText = copyBtn.querySelector('.btn-text') as HTMLElement;
      const code = copyBtn.getAttribute('data-code') || '';

      try {
        await navigator.clipboard.writeText(code);

        // Show success state
        if (copyIcon) copyIcon.style.display = 'none';
        if (checkIcon) checkIcon.style.display = 'inline-flex';
        if (btnText) btnText.textContent = 'Copied!';
        copyBtn.classList.add('copied');

        // Reset state after 2 seconds
        setTimeout(() => {
          if (copyIcon) copyIcon.style.display = 'inline-flex';
          if (checkIcon) checkIcon.style.display = 'none';
          if (btnText) btnText.textContent = 'Copy Code';
          copyBtn.classList.remove('copied');
        }, 2000);
      } catch (err) {
        console.error('Failed to copy code: ', err);
      }
    });
  }
</script>
