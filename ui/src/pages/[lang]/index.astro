---
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/Sidebar.astro';
import { languages, useTranslations } from '../../i18n/ui';
import lessons from '../../data/lessons.json';
import { BookOpen, Settings, Zap, ArrowRight } from '@lucide/astro';

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as any);
const totalLessons = lessons.length;
---

<Layout title={t('site.title')}>
  <div class="app-container" id="app-container">
    <Sidebar activeLang={lang} />
    

    
    <main class="welcome-container animate-fade-in">
      <div class="welcome-content">
        <header class="welcome-header">
          <div class="welcome-badge">{t('welcome.badge')}</div>
          <h1>{t('welcome.title')}</h1>
          <p class="subtitle">
            {t('welcome.subtitle')}
          </p>
        </header>

        <div class="cta-group">
          <a href={`/ultimate-python/${lang}/syntax/variable/`} class="btn btn-primary">
            {t('nav.start')}
            <ArrowRight size={16} class="btn-arrow" />
          </a>
          <a href="https://github.com/huangsam/ultimate-python" target="_blank" rel="noopener" class="btn btn-secondary">
            {t('nav.github')}
          </a>
        </div>

        <section class="info-grid">
          <div class="info-card">
            <div class="info-icon"><BookOpen size={24} /></div>
            <h3>{totalLessons} {t('card.lessons.title')}</h3>
            <p>{t('card.lessons.desc')}</p>
          </div>
          
          <div class="info-card">
            <div class="info-icon"><Settings size={24} /></div>
            <h3>{t('card.stdlib.title')}</h3>
            <p>{t('card.stdlib.desc')}</p>
          </div>
          
          <div class="info-card">
            <div class="info-icon"><Zap size={24} /></div>
            <h3>{t('card.run.title')}</h3>
            <p>{t('card.run.desc')}</p>
          </div>
        </section>

        <section class="philosophy-section">
          <h3>{t('zen.title')}</h3>
          <blockquote>
            <p>"Beautiful is better than ugly."</p>
            <p>"Explicit is better than implicit."</p>
            <p>"Simple is better than complex."</p>
            <cite>— Tim Peters</cite>
          </blockquote>
        </section>
      </div>
    </main>
  </div>
</Layout>

<style>
  .welcome-container {
    flex: 1;
    overflow-y: auto;
    padding: 4rem 2rem;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    background-color: var(--bg-primary);
  }

  .welcome-content {
    max-width: 800px;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
  }

  .welcome-header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .welcome-badge {
    align-self: flex-start;
    padding: 0.35rem 0.75rem;
    border-radius: 20px;
    background-color: var(--forest-green-soft);
    color: var(--forest-green);
    font-size: 0.85rem;
    font-weight: 600;
  }

  h1 {
    font-size: 2.75rem;
    line-height: 1.2;
    margin-top: 0.5rem;
  }

  .subtitle {
    font-size: 1.15rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .cta-group {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .btn {
    padding: 0.8rem 1.6rem;
    border-radius: 6px;
    font-weight: 500;
    transition: all var(--transition-speed);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .btn-primary {
    background-color: var(--forest-green);
    color: var(--bg-primary);
  }

  .btn-primary:hover {
    background-color: var(--forest-green-light);
    color: var(--bg-primary);
    transform: translateY(-1px);
  }

  .btn-secondary {
    border: 1px solid var(--border-color);
    background-color: var(--bg-secondary);
    color: var(--text-primary);
  }

  .btn-secondary:hover {
    background-color: var(--bg-tertiary);
    transform: translateY(-1px);
  }

  .btn-arrow {
    transition: transform var(--transition-speed);
  }

  .btn-primary:hover .btn-arrow {
    transform: translateX(4px);
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }

  .info-card {
    padding: 1.5rem;
    border-radius: 8px;
    border: 1px solid var(--border-color);
    background-color: var(--bg-secondary);
    transition: transform var(--transition-speed);
  }

  .info-card:hover {
    transform: translateY(-2px);
    border-color: var(--forest-green);
  }

  .info-icon {
    color: var(--forest-green);
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
  }

  .info-card h3 {
    font-size: 1.15rem;
    margin-bottom: 0.5rem;
  }

  .info-card p {
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .philosophy-section {
    padding-top: 2rem;
    border-top: 1px solid var(--border-color);
  }

  .philosophy-section h3 {
    font-size: 1.25rem;
    margin-bottom: 1rem;
  }

  blockquote {
    border-left: 3px solid var(--forest-green);
    padding-left: 1.25rem;
    font-family: var(--font-serif);
    color: var(--text-secondary);
    font-size: 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  blockquote cite {
    margin-top: 0.5rem;
    font-size: 0.9rem;
    color: var(--text-secondary);
    font-style: normal;
  }

  @media (max-width: 900px) {
    #app-container {
      flex-direction: column !important;
    }

    .welcome-container {
      padding: 3rem 1.25rem;
    }

    :global(html.sidebar-transitioning) .welcome-container {
      transition: padding-left var(--transition-speed);
    }

    :global(html.sidebar-collapsed) .welcome-container {
      padding-left: 3.5rem;
    }

    .welcome-content {
      gap: 2.5rem;
    }

    h1 {
      font-size: 2rem;
    }

    .subtitle {
      font-size: 1rem;
    }

    .cta-group {
      flex-wrap: wrap;
      gap: 0.75rem;
      width: 100%;
    }

    .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
